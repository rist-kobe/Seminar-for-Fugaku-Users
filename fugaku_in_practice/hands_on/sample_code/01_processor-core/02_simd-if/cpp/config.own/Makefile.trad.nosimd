CC=FCC
CFLAGS=-g -std=gnu++14 -v -KSVE -KA64FX \
       -Kfast -Knosimd -Knoswp -Kstrict_aliasing -Knoocl \
       -Knoomitfp -Koptmsg=2 -Nlst=t
LIB=

.SUFFIXES: .o .cpp

SRC = main.cpp mykernel.cpp timer.cpp

OBJ = $(SRC:.cpp=.o)

EXE=run.x

$(EXE): $(OBJ)
	$(CC) $(CFLAGS) -o $@ $(OBJ) $(LIB)

mykernel.o: mykernel.cpp

main.o: mykernel.o timer.o main.cpp

timer.o: timer.cpp

.cpp.o:
	$(CC) $(CFLAGS) -c $< -o $@

.PHONY:
clean:
	rm -f *.o *.lst

.PHONY:
veryclean: clean
	rm -f $(EXE)

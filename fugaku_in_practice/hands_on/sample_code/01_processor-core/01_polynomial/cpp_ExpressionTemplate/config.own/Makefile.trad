CC=FCC
CFLAGS=-g -Nnoclang -V -std=c++14 -stdlib=stdlibc++ \
        -KA64FX -KSVE -Kfast -Knoomitfp -Ksimd=auto -Knoswp -Kstrict_aliasing \
        -Koptmsg=2 -Nlst=t -Nline 
##########################################################################
SRC = \
	main.cpp \
	mykernel.cpp

OBJ = $(SRC:.cpp=.o)

.SUFFIXES: .cpp .o

run.x: $(OBJ)
	$(CC) $(CFLAGS) $(OBJ) -o $@

.cpp.o:
	$(CC) $(CFLAGS) -c $< -o $@

main.o: main.cpp

mykernel.o: mykernel.cpp

.PHONY: clean
clean:
	rm -f *.o *~ *.lst

.PHONY: veryclean
veryclean: clean
	rm -f *.x
